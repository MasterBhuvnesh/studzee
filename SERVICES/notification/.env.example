# Copy to .env for local runs. Never commit the filled version.
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Postgres (notification_db)
DATABASE_URL=postgresql://studzee:studzee@localhost:5432/notification_db?schema=public

# RabbitMQ
RABBITMQ_URL=amqp://studzee:studzee@localhost:5672

# Clerk
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# SMTP (transactional email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=xxx
SMTP_PASSWORD=xxx
EMAIL_FROM=Studzee <no-reply@studzee.in>
