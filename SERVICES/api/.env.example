# Copy to .env for local runs. Never commit the filled version.
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Postgres (api_db)
DATABASE_URL=postgresql://studzee:studzee@localhost:5432/api_db?schema=public

# Redis cache
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://studzee:studzee@localhost:5672

# Clerk
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx

# OpenAI compatible LLM endpoint (Groq / OpenRouter / Ollama)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=xxx
LLM_MODEL=llama-3.3-70b-versatile

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_S3_BUCKET=studzee-assets

# RevenueCat webhook shared secret (Authorization header value)
RC_WEBHOOK_SECRET=xxx

# Cache TTLs (seconds)
LIST_CACHE_TTL=60
DOC_CACHE_TTL=300
