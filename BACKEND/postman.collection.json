			"name": "PDFs",
			"item": [
				{
					"name": "List All PDFs",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/pdfs?page=1&limit=20",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"pdfs"
							],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "20"
								}
							]
						},
						"description": "Retrieve a paginated list of all documents with uploaded PDFs."
					},
					"response": []
				}
			]
		},
		{
			"name": "Admin",
			"item": [
				{
					"name": "Create Document",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{clerkToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"New Tutorial\",\n  \"content\": \"Complete tutorial content goes here...\",\n  \"summary\": \"Optional summary of the content\",\n  \"facts\": \"Optional interesting facts\",\n  \"quiz\": {\n    \"q1\": {\n      \"que\": \"Sample question?\",\n      \"ans\": \"Correct answer\",\n      \"options\": [\"Option 1\", \"Option 2\", \"Correct answer\", \"Option 4\"]\n    }\n  },\n  \"key_notes\": {\n    \"note1\": \"Important point 1\",\n    \"note2\": \"Important point 2\"\n  }\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/admin/documents",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"admin",
								"documents"
							]
						},
						"description": "Create a new document. Requires Admin role."
					},
					"response": []
				},
