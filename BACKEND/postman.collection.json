		},
		{
			"name": "Content",
			"item": [
				{
					"name": "Get Today's Content",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/content/today",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"content",
								"today"
							]
						},
						"description": "Retrieve documents created today (IST timezone)."
					},
					"response": []
				},
				{
					"name": "Get Paginated Content",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/content?page=1&limit=20",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"content"
							],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "20"
								}
							]
						},
						"description": "Retrieve a paginated list of documents."
					},
					"response": []
				},
				{
					"name": "Get Document by ID",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{clerkToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/content/:id",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"content",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "507f1f77bcf86cd799439011",
									"description": "MongoDB document ID"
								}
							]
						},
						"description": "Retrieve a complete document by its ID. Requires authentication."
					},
					"response": []
				}
			]
		},
