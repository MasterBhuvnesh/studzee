									"key": "token",
									"value": "{{clerkToken}}",
									"type": "string"
								}
							]
						},
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/admin/documents/:id",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"admin",
								"documents",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "507f1f77bcf86cd799439011"
								}
							]
