									"key": "token",
									"value": "{{clerkToken}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Updated Tutorial Title\",\n  \"summary\": \"Updated summary text\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/admin/documents/:id",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"admin",
