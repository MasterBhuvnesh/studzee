# Copy to K8S/secrets/.env, fill real values, then create the cluster secret:
#   kubectl -n studzee create secret generic studzee-secrets \
#     --from-env-file=K8S/secrets/.env
# The real .env is gitignored. Never commit filled secrets.

# Local Postgres password. Must match the password embedded in the two
# DATABASE_URL values below.
POSTGRES_PASSWORD=studzee

# Per-service database URLs. Host "postgres" is the in-cluster service.
API_DATABASE_URL=postgresql://studzee:studzee@postgres:5432/api_db?schema=public
NOTIFICATION_DATABASE_URL=postgresql://studzee:studzee@postgres:5432/notification_db?schema=public

# Clerk (backend verifies JWTs). Dev-instance keys are fine locally.
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# LLM (OpenAI-compatible). Base URL and model live in the ConfigMap.
LLM_API_KEY=

# AWS S3 for presigned uploads. Region and bucket live in the ConfigMap.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# RevenueCat webhook shared secret.
RC_WEBHOOK_SECRET=

# SMTP credentials. Host, port and from-address live in the ConfigMap.
SMTP_USER=
SMTP_PASSWORD=
